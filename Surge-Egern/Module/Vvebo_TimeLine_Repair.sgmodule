#!name=VVebo时间线修复
#!desc=修复失效的用户时间线和我的页面。使用此插件前需要禁用微博去广告插件，避免插件冲突导致失效。
#!author=suiyuran[https://github.com/suiyuran], androidcn[https://github.com/androidcn]
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/VVebo.png
#!category=Repair
#!openUrl=https://apps.apple.com/app/id670910957
#!tag=功能增强
#!homepage=https://hub.kelee.one
#!date=2026-06-09 18:25:08

[Script]
修复时间线 = type=http-request, pattern=^https:\/\/api\.weibo\.cn\/2\/users\/show\?, script-path=https://raw.githubusercontent.com/szt416/Rules/refs/heads/main/Surge-Egern/Scripts/Vvebo/fix_vvebo_timeline.js

修复时间线 = type=http-request, pattern=^https:\/\/api\.weibo\.cn\/2\/statuses\/user_timeline\?, script-path=https://raw.githubusercontent.com/szt416/Rules/refs/heads/main/Surge-Egern/Scripts/Vvebo/fix_vvebo_timeline.js

修复时间线 = type=http-request, pattern=^https:\/\/api\.weibo\.cn\/2\/remind\/unread_count\?, script-path=https://raw.githubusercontent.com/szt416/Rules/refs/heads/main/Surge-Egern/Scripts/Vvebo/fix_vvebo_timeline.js

修复时间线 = type=http-response, pattern=^https:\/\/api\.weibo\.cn\/2\/profile\/statuses\/tab\?, script-path=https://raw.githubusercontent.com/szt416/Rules/refs/heads/main/Surge-Egern/Scripts/Vvebo/fix_vvebo_timeline.js, requires-body=true

修复我的页面 = type=http-response, pattern=^https:\/\/api\.weibo\.cn\/2\/cardlist\?, script-path=https://raw.githubusercontent.com/szt416/Rules/refs/heads/main/Surge-Egern/Scripts/Vvebo/fix_vvebo_my.js, requires-body=true

[MITM]
hostname = %APPEND% api.weibo.cn
